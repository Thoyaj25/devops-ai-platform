generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  VENDOR
  CUSTOMER
}

enum ProductStatus {
  DRAFT
  ACTIVE
  OUT_OF_STOCK
  ARCHIVED
}

model User {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  passwordHash String
  role         UserRole   @default(CUSTOMER)

  vendor        Vendor?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Vendor {
  id          String    @id @default(cuid())
  name        String
  description String?

  ownerId String @unique
  owner   User   @relation(fields: [ownerId], references: [id])

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id       String @id @default(cuid())
  name     String @unique
  slug     String @unique

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id          String @id @default(cuid())
  title       String
  slug        String @unique
  description String?

  price Decimal @db.Decimal(10,2)

  stock Int @default(0)

  status ProductStatus @default(DRAFT)

  vendorId String
  vendor   Vendor @relation(fields: [vendorId], references: [id])

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  images ProductImage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([vendorId])
  @@index([categoryId])
  @@index([status])
}

model ProductImage {
  id String @id @default(cuid())

  imageUrl String

  sortOrder Int @default(0)

  productId String
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([productId])
}