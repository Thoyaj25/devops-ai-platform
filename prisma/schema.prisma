generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}


enum UserRole {
  ADMIN
  DEVOPS_ENGINEER
  DEVELOPER
  VIEWER
}

enum ProjectStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum DeploymentStatus {
  SUCCESS
  FAILED
  RUNNING
  ROLLBACK
}

enum EnvironmentType {
  DEVELOPMENT
  STAGING
  PRODUCTION
}


model User {
  id            String   @id @default(cuid())
  name          String?
  email         String   @unique
  passwordHash  String?
  role          UserRole @default(DEVELOPER)

  projects      Project[]
  auditLogs     AuditLog[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}


model Project {
  id            String        @id @default(cuid())
  name          String
  description   String?
  status        ProjectStatus @default(ACTIVE)

  ownerId       String
  owner         User          @relation(fields: [ownerId], references: [id])

  environments  Environment[]
  pipelines     Pipeline[]
  deployments   Deployment[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}


model Environment {
  id            String          @id @default(cuid())
  name          String
  type          EnvironmentType

  projectId     String
  project       Project         @relation(fields: [projectId], references: [id])

  deployments   Deployment[]

  createdAt     DateTime @default(now())
}


model Pipeline {
  id            String   @id @default(cuid())
  name          String

  provider      String?
  repository    String?

  projectId     String
  project       Project @relation(fields: [projectId], references: [id])

  deployments   Deployment[]

  createdAt     DateTime @default(now())
}


model Deployment {
  id             String           @id @default(cuid())
  version        String?
  status         DeploymentStatus @default(RUNNING)

  projectId      String
  project        Project @relation(fields: [projectId], references: [id])

  environmentId  String
  environment    Environment @relation(fields: [environmentId], references: [id])

  pipelineId     String
  pipeline       Pipeline @relation(fields: [pipelineId], references: [id])

  logs           String?

  createdAt      DateTime @default(now())
}


model Cluster {
  id             String @id @default(cuid())

  name           String
  provider       String?
  region         String?

  createdAt      DateTime @default(now())
}


model AuditLog {
  id             String   @id @default(cuid())

  action         String
  resource       String

  userId         String
  user           User @relation(fields: [userId], references: [id])

  metadata       Json?

  createdAt      DateTime @default(now())
}