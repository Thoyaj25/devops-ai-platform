generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String     @id @default(cuid())
  name         String?
  email        String     @unique
  passwordHash String?
  role         UserRole   @default(DEVELOPER)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @default(now()) @updatedAt
  auditLogs    AuditLog[]
  projects     Project[]
}

model Project {
  id           String        @id @default(cuid())
  name         String
  description  String?
  status       ProjectStatus @default(ACTIVE)
  ownerId      String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @default(now()) @updatedAt
  clusterId    String?
  deployments  Deployment[]
  environments Environment[]
  pipelines    Pipeline[]
  cluster      Cluster?      @relation(fields: [clusterId], references: [id])
  owner        User          @relation(fields: [ownerId], references: [id])
}

model Cluster {
  id        String    @id @default(cuid())
  name      String
  provider  String?
  region    String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt
  projects  Project[]
}

model Environment {
  id          String          @id @default(cuid())
  name        String
  type        EnvironmentType
  projectId   String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @default(now()) @updatedAt
  deployments Deployment[]
  project     Project         @relation(fields: [projectId], references: [id])
}

model Pipeline {
  id            String       @id @default(cuid())
  name          String
  provider      String?
  repository    String?
  projectId     String
  createdAt     DateTime     @default(now())
  branch        String?      @default("main")
  buildCommand  String?
  deployCommand String?
  updatedAt     DateTime     @default(now()) @updatedAt
  deployments   Deployment[]
  project       Project      @relation(fields: [projectId], references: [id])
}

model Deployment {
  id            String           @id @default(cuid())
  version       String?
  status        DeploymentStatus @default(RUNNING)

  projectId     String
  environmentId String
  pipelineId    String

  logs          String?

  // Runtime deployment metadata
  hostPort      Int?
  containerId   String?
  containerUrl  String?
  isHealthy     Boolean          @default(false)

  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @default(now()) @updatedAt

  environment   Environment      @relation(fields: [environmentId], references: [id])
  pipeline      Pipeline         @relation(fields: [pipelineId], references: [id])
  project       Project          @relation(fields: [projectId], references: [id])
  jobs          DeploymentJob[]
}

model DeploymentJob {
  id           String     @id @default(cuid())
  deploymentId String
  status       JobStatus  @default(PENDING)
  attempts     Int        @default(0)
  error        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @default(now()) @updatedAt
  nextRetryAt  DateTime?
  completedAt  DateTime?
  startedAt    DateTime?
  deployment   Deployment @relation(fields: [deploymentId], references: [id])
}

model WorkerHeartbeat {
  id        String   @id @default(cuid())
  workerId  String   @unique
  lastSeen  DateTime @default(now()) @updatedAt
  createdAt DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  resource  String
  userId    String
  metadata  Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

enum UserRole {
  ADMIN
  DEVOPS_ENGINEER
  DEVELOPER
  VIEWER
}

enum ProjectStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum DeploymentStatus {
  SUCCESS
  FAILED
  RUNNING
  ROLLBACK
}

enum EnvironmentType {
  DEVELOPMENT
  STAGING
  PRODUCTION
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}