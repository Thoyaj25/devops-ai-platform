generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --- Enums ---
enum UserRole {
  ADMIN
  DEVOPS_ENGINEER
  DEVELOPER
  VIEWER
}

enum ProjectStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum DeploymentStatus {
  CREATED
  QUEUED
  RUNNING
  SUCCESS
  FAILED
  ROLLBACK
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum EnvironmentType {
  DEVELOPMENT
  STAGING
  PRODUCTION
}

// --- Models ---
model User {
  id           String     @id @default(cuid())
  name         String?
  email        String     @unique
  passwordHash String?
  role         UserRole   @default(DEVELOPER)
  projects     Project[]
  auditLogs    AuditLog[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Project {
  id           String        @id @default(cuid())
  name         String
  description  String?
  status       ProjectStatus @default(ACTIVE)

  // Ownership
  ownerId      String
  owner        User          @relation(fields: [ownerId], references: [id])

  // Infrastructure Mapping
  clusterId    String?
  cluster      Cluster?      @relation(fields: [clusterId], references: [id])

  // Relations
  environments Environment[]
  pipelines    Pipeline[]
  deployments  Deployment[]

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Environment {
  id          String          @id @default(cuid())
  name        String
  type        EnvironmentType

  projectId   String
  project     Project         @relation(fields: [projectId], references: [id])
  deployments Deployment[]

  createdAt   DateTime        @default(now())
}

model Pipeline {
  id          String       @id @default(cuid())
  name        String
  provider    String?
  repository  String?

  projectId   String
  project     Project      @relation(fields: [projectId], references: [id])
  deployments Deployment[]

  createdAt   DateTime     @default(now())
}

model Deployment {
  id            String           @id @default(cuid())
  version       String?
  status        DeploymentStatus @default(CREATED)
  url           String?
  logs          String?
  currentStage  String?
  
  projectId     String
  project       Project          @relation(fields: [projectId], references: [id])
  environmentId String
  environment   Environment      @relation(fields: [environmentId], references: [id])
  pipelineId    String
  pipeline      Pipeline         @relation(fields: [pipelineId], references: [id])

  jobs          DeploymentJob[]
  
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
}

model DeploymentJob {
  id           String     @id @default(cuid())
  deploymentId String
  status       JobStatus  @default(PENDING)
  attempts     Int        @default(0)
  error        String?
  
  deployment   Deployment @relation(fields: [deploymentId], references: [id])
  
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Cluster {
  id        String    @id @default(cuid())
  name      String    @unique
  provider  String?
  region    String?
  projects  Project[]

  createdAt DateTime  @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  resource  String
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  metadata  Json?
  createdAt DateTime @default(now())
}